NODE_ENV=development
PORT=3000
PUBLIC_ORIGIN=http://localhost:3000
# Required for every deployed runtime. Use a pooled/serverless PostgreSQL URL
# (for example, Neon) rather than a local file path.
DATABASE_URL=
TXLINE_ENV=devnet
TXLINE_API_TOKEN=
TXLINE_GUEST_BASE_URL=https://txline-dev.txodds.com
TXLINE_API_BASE_URL=https://txline-dev.txodds.com/api
SOLANA_CLUSTER=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
FINAL_WHISTLE_PROGRAM_ID=Hf4KSaGy7EHEaT9jMCo9nKx2uQRz6BEsYS3DrprkDaPw
TXLINE_PROGRAM_ID=6pW64gN1s2uqjHkn1unFeEjAwJkPGHoppGvS715wyP2J
# The app accepts only wrapped native SOL. Users send ordinary devnet SOL and
# the browser wraps it atomically for escrow, then unwraps payouts automatically.
ALLOWED_STAKE_MINTS=So11111111111111111111111111111111111111112
# Optional URL to a devnet SOL faucet or setup guide shown in the wallet panel.
DEVNET_TOKEN_FAUCET_URL=
# Keep true in production so repeated writes cannot be replayed accidentally.
REQUIRE_IDEMPOTENCY_KEYS=true
# Set to true only when the deployment is behind a proxy that overwrites forwarded IP headers.
TRUST_PROXY=false
FIXTURE_REFRESH_MIN_INTERVAL_MS=30000
UPSTREAM_TIMEOUT_MS=8000
RATE_LIMIT_MAX_BUCKETS=10000
