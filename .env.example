NODE_ENV=development
PORT=3000
PUBLIC_ORIGIN=http://localhost:3000
# Required for every deployed runtime. Use a pooled/serverless PostgreSQL URL
# (for example, Neon) rather than a local file path.
DATABASE_URL=
TXLINE_ENV=devnet
TXLINE_API_TOKEN=
TXLINE_GUEST_BASE_URL=https://txline-dev.txodds.com
TXLINE_API_BASE_URL=https://txline-dev.txodds.com/api
SOLANA_CLUSTER=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
FINAL_WHISTLE_PROGRAM_ID=DaW6BCZ4AKUNwyEaoqik6xbrx9JcuqRbfhwzDstDEJWF
TXLINE_PROGRAM_ID=6pW64gN1s2uqjHkn1unFeEjAwJkPGHoppGvS715wyP2J
# Required for production settlement. Must be a TxLINE-provable score stat key whose value is the soccer phase ID.
TXLINE_FINALITY_STAT_KEY=
# Comma-separated stake mint allowlist. Defaults in code: devnet USDC and TxLINE devnet USDT only.
ALLOWED_STAKE_MINTS=
# Optional comma-separated fixture IDs that should appear as clearly labeled replay fixtures in public beta.
BETA_REPLAY_FIXTURE_IDS=
# Optional URL to a devnet stake-token faucet or setup guide shown in the wallet panel.
DEVNET_TOKEN_FAUCET_URL=
# Keep true in production so repeated writes cannot be replayed accidentally.
REQUIRE_IDEMPOTENCY_KEYS=true
# Set to true only when the deployment is behind a proxy that overwrites forwarded IP headers.
TRUST_PROXY=false
STREAM_MAX_IP_CLIENTS=3
RATE_LIMIT_MAX_BUCKETS=10000
